{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "SSH Port Forwarder (SPF) — 业务 spf_* 指标在上方，Go/进程/抓取 指标在下方。导入后请选择 Prometheus 数据源。",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "业务指标 (spf_*)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.5 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(spf_host_health{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"})",
          "legendFormat": "__auto",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "健康 Host 数 (sum)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "count(spf_host_health{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"})",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "已上报 Host 数",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "mappings": [],
          "max": 1,
          "min": 0,
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 0.99 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "avg(spf_host_health{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"})",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Host 健康均值",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 15, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(spf_rule_health{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"})",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "健康 Rule 数 (sum)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 8,
            "showPoints": "auto",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "max": 1.2,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "spf_host_health{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}",
          "legendFormat": "{{host_name}} ({{host_id}})",
          "refId": "A"
        }
      ],
      "title": "Host 健康",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0, "spanNulls": true },
          "mappings": [],
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum by (host_id, host_name) (rate(spf_host_latency_seconds_sum{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}[5m])) / sum by (host_id, host_name) (rate(spf_host_latency_seconds_count{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{host_name}}",
          "refId": "A"
        }
      ],
      "title": "SSH keepalive 平均延迟 (秒)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5, "spanNulls": true } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, host_id, host_name) (rate(spf_host_latency_seconds_bucket{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}[5m])))",
          "legendFormat": "p95 {{host_name}}",
          "refId": "A"
        }
      ],
      "title": "Host keepalive 延迟 p95 (秒)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "spf_host_rule_load{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}",
          "legendFormat": "{{host_name}} ({{host_id}})",
          "refId": "A"
        }
      ],
      "title": "每 Host 活跃规则负载",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "max": 1.2, "min": 0, "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 1, "spanNulls": true } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "spf_rule_health{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}",
          "legendFormat": "{{rule_name}} (g={{group_id}})",
          "refId": "A"
        }
      ],
      "title": "规则健康",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0 }, "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum by (rule_id, rule_name, from_host_id, to_host_id) (rate(spf_rule_host_switch_total{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{rule_name}}: {{from_host_id}} -> {{to_host_id}}",
          "refId": "A"
        }
      ],
      "title": "规则切换 active host 速率 (次/秒)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [ { "id": "custom.width", "value": 80 } ] }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 27 },
      "id": 12,
      "options": { "cellHeight": "sm", "showHeader": true, "sortBy": [ { "desc": true, "displayName": "group_id" } ] },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "spf_host_group_info{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Host 与 Group 归属 (spf_host_group_info)",
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "indexByName": {}, "renameByName": {} } }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 50,
      "title": "服务与运行时 (up / process / go / promhttp)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "value": "0", "text": "DOWN" }, { "type": "value", "value": "1", "text": "UP" } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } } },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 34 },
      "id": 51,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": [ "lastNotNull" ] } },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "up{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "up",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 1, "spanNulls": true }, "unit": "s/s" } },
      "gridPos": { "h": 7, "w": 10, "x": 4, "y": 34 },
      "id": 52,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "rate(process_cpu_seconds_total{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "CPU s/s",
          "refId": "A"
        }
      ],
      "title": "Process CPU 使用率 (rate)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" } },
      "gridPos": { "h": 7, "w": 10, "x": 14, "y": 34 },
      "id": 53,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "process_resident_memory_bytes{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ],
      "title": "Process RSS",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 41 },
      "id": 54,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "go_goroutines{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}",
          "legendFormat": "goroutines",
          "refId": "A"
        }
      ],
      "title": "Go Goroutines",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" } },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 41 },
      "id": 55,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "go_memstats_alloc_bytes{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}",
          "legendFormat": "alloc",
          "refId": "A"
        }
      ],
      "title": "Go Heap 在用 (alloc)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 41 },
      "id": 56,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "pluginVersion": "v12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum by (code) (rate(promhttp_metric_handler_requests_total{job=~\"$job\",namespace=~\"$namespace\",instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "title": "Prometheus /metrics 请求速率 (按 HTTP code)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [ "ssh-port-forwarder", "spf", "prometheus" ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "数据源",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(up, job)",
        "hide": 0,
        "includeAll": true,
        "label": "job",
        "name": "job",
        "options": [],
        "query": "label_values(up, job)",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(up{job=~\"$job\"}, namespace)",
        "hide": 0,
        "includeAll": true,
        "label": "namespace",
        "name": "namespace",
        "query": "label_values(up{job=~\"$job\"}, namespace)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(up{job=~\"$job\",namespace=~\"$namespace\"}, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "instance",
        "name": "instance",
        "query": "label_values(up{job=~\"$job\",namespace=~\"$namespace\"}, instance)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
